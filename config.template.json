{
	"language": "auto",
	"generation": {
		"align": "ask"
	},
	"runner": {
		"command": "pi",
		"tools": ["read", "grep", "find", "ls", "bash"],
		"excludeTools": ["write", "edit"],
		"timeoutMs": 1200000,
		"serviceTier": "default",
		"extensions": []
	},
	"modelRoles": {
		"planner": {
			"model": "anthropic/claude-fable-5",
			"thinking": "high"
		},
		"executor": {
			"model": "openai-codex/gpt-5.5",
			"thinking": "xhigh"
		},
		"reviewers": [
			{
				"model": "openai-codex/gpt-5.4",
				"thinking": "high"
			},
			{
				"model": "openai-codex/gpt-5.4-mini",
				"thinking": "xhigh"
			},
			{
				"model": "deepseek/deepseek-v4-flash",
				"thinking": "xhigh"
			}
		]
	},
	"transcript": {
		"maxUser": 6000,
		"maxAssistant": 3000,
		"maxTranscript": 75000
	},
	"acceptance": {
		"enabled": true
	},
	"quality": {
		"enabled": true,
		"mode": "autoFix",
		"runAfterCompletion": true
	}
}
