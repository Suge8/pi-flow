			{
				"model": "openai-codex/gpt-5.6-sol",
				"thinking": "high"
			},
			{
				"model": "anthropic/claude-sonnet-5",
				"thinking": "high"
			},
			{
				"model": "deepseek/deepseek-v4-flash",
				"thinking": "xhigh"
			}
		]
	},
	"advisor": {
		"enabled": true
	},
	"prewalk": {
